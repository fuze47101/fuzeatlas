generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum SourceSystem {
  KNACK
  CSV
  MANUAL
  API
}

enum PipelineStage {
  LEAD
  PRESENTATION
  BRAND_TESTING
  FACTORY_ONBOARDING
  FACTORY_TESTING
  PRODUCTION
  BRAND_EXPANSION
  ARCHIVE
  CUSTOMER_WON
}

enum TestType {
  ICP
  ANTIBACTERIAL
  FUNGAL
  ODOR
  UV
  MICROFIBER
  OTHER
}

enum TestStatus {
  REQUESTED
  IN_PROGRESS
  PASSED
  FAILED
  RETEST
  PASSED_COMPLETE
}

enum DocKind {
  REPORT
  IMAGE
  SUBMISSION_DOC
  SOW_DOC
  LAB_FORM
  OTHER
}

// ComplianceCategory is now a free-form String on ComplianceDocument.category
// Built-in values: SDS_MSDS, TDS, BLUESIGN, ZDHC, OEKO_TEX, GOTS, EPA, REACH, COA, COC, ISO, IMPORT_EXPORT, OTHER
// Admins can also create custom categories

enum SOWStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  COMPLETE
  CANCELLED
}

enum UserRole {
  ADMIN
  EMPLOYEE
  SALES_MANAGER
  SALES_REP
  FABRIC_MANAGER
  TESTING_MANAGER
  FACTORY_MANAGER
  FACTORY_USER
  BRAND_USER
  DISTRIBUTOR_USER
  PUBLIC
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

// ─────────────────────────────────────────────
// COMPETITOR PRICE OVERRIDES (admin espionage data)
// ─────────────────────────────────────────────

model CompetitorPriceOverride {
  id              String  @id @default(cuid())
  competitorId    String  @unique  // matches id from COMPETITORS array in competitors.ts

  // Distributor pricing (real espionage data from China distributors etc.)
  chemicalPricePerKg         Float?   // USD/kg of antimicrobial as purchased
  chemicalPriceSource        String?  // "China distributor quote", "India contact", etc.
  chemicalPriceDate          DateTime? // when the price was obtained

  // Binder pricing overrides
  binderPricePerKg           Float?   // USD/kg of binder chemical

  // Application cost overrides (per linear meter)
  estimatedCostPerMeterLow      Float?
  estimatedCostPerMeterHigh     Float?
  estimatedCostPerMeterTypical  Float?

  // Re-treatment multiplier override
  retreatmentCostMultiplier  Float?

  // Notes
  notes          String?  // free-form notes about the source, confidence, etc.

  updatedBy      String?  // user name who last updated
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([competitorId])
}

// ─────────────────────────────────────────────
// AUDIT / IMPORT TRACKING
// ─────────────────────────────────────────────

model SourceRecord {
  id             String       @id @default(cuid())
  sourceSystem   SourceSystem @default(CSV)
  sourceTable    String
  sourceRecordId String?
  sourceKey      String?
  raw            Json
  importedAt     DateTime     @default(now())

  brandId      String?
  factoryId    String?
  labId        String?
  submissionId String?
  testRunId      String?
  distributorId  String?

  brand      Brand?            @relation(fields: [brandId], references: [id])
  factory    Factory?          @relation(fields: [factoryId], references: [id])
  lab        Lab?              @relation(fields: [labId], references: [id])
  submission FabricSubmission? @relation(fields: [submissionId], references: [id])
  testRun    TestRun?          @relation(fields: [testRunId], references: [id])
  distributor Distributor?      @relation(fields: [distributorId], references: [id])

  @@index([sourceSystem, sourceTable])
  @@index([sourceRecordId])
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id       String     @id @default(cuid())
  name     String
  email    String     @unique
  password String?
  role     UserRole   @default(PUBLIC)
  status   UserStatus @default(ACTIVE)

  // Security flags
  mustChangePassword Boolean  @default(false)  // Force password change on next login
  emailVerified      Boolean  @default(false)  // Email address verified
  emailVerifyToken   String?  @unique          // Verification token
  emailVerifyExpiry  DateTime?                 // Token expiry
  passwordChangedAt  DateTime?                 // Last password change timestamp

  salesManagerId String?
  salesManager   User?   @relation("SalesManagerReps", fields: [salesManagerId], references: [id])
  managedReps    User[]  @relation("SalesManagerReps")

  brandId       String?
  brand         Brand?       @relation("BrandUsers", fields: [brandId], references: [id])
  factoryId     String?
  factory       Factory?     @relation("FactoryUsers", fields: [factoryId], references: [id])
  distributorId String?
  distributor   Distributor? @relation("DistributorUsers", fields: [distributorId], references: [id])

  assignedBrands    Brand[]    @relation("BrandSalesRep")
  assignedFactories Factory[]  @relation("FactorySalesRep")

  notes          Note[]
  accessRequest  AccessRequest?
  testRequestsCreated  TestRequest[] @relation("TestRequestRequester")
  testRequestsApproved TestRequest[] @relation("TestRequestApprover")
  notifications Notification[] @relation("UserNotifications")
  auditLogs AuditLog[] @relation("UserAuditLogs")
  passwordResets PasswordResetToken[] @relation("PasswordResets")
  organizedMeetings Meeting[] @relation("MeetingOrganizer")
  complianceUploads ComplianceDocument[]
  sampleTrials     SampleTrialRequest[] @relation("TrialRequester")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([role])
  @@index([email])
}

// ─────────────────────────────────────────────
// BRANDS / CUSTOMERS
// ─────────────────────────────────────────────

model Brand {
  id     String @id @default(cuid())
  name   String @unique
  knackId String? @unique

  pipelineStage      PipelineStage @default(LEAD)
  customerType       String?
  leadReferralSource String?
  dateOfInitialContact DateTime?

  website        String?
  linkedInProfile String?
  backgroundInfo String?
  researchData   Json?
  researchDate   DateTime?

  projectType        String?
  projectDescription String?
  presentationDate   DateTime?
  forecast           String?
  deliverables       String?

  raw Json?

  salesRepId String?
  salesRep   User?  @relation("BrandSalesRep", fields: [salesRepId], references: [id])

  contacts    Contact[]
  factories   BrandFactory[]
  submissions FabricSubmission[]
  fabrics     Fabric[]
  projects    Project[]
  products    Product[]
  sows        SOW[]
  invoices    Invoice[]
  notes       Note[]
  users       User[]         @relation("BrandUsers")
  testRequests TestRequest[] @relation("TestRequestBrand")
  sampleTrials SampleTrialRequest[] @relation("TrialBrand")
  meetings     Meeting[]      @relation("MeetingBrand")
  sourceRecords SourceRecord[]
  engagement BrandEngagement? @relation("BrandEngagement")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineStage])
  @@index([name])
}

// ─────────────────────────────────────────────
// FACTORIES / TEXTILE MILLS
// ─────────────────────────────────────────────

model Factory {
  id      String @id @default(cuid())
  name    String
  knackId String? @unique

  chineseName  String?
  millType     String?
  specialty    String?
  purchasing   String?
  annualSales  String?

  address          String?
  city             String?
  state            String?
  country          String?
  secondaryCountry String?

  development          String?
  presentationComplete Boolean?
  customerType         String?
  brandNominated       String?

  // ─── Searchable / Discovery Fields ─────────────
  productTypes      String?   // JSON array: ["activewear","denim","intimates","socks","wovens","knits","outerwear","home_textiles","non_woven","medical","industrial"]
  capabilities      String?   // JSON array: ["dyeing","finishing","printing","knitting","weaving","cut_sew","coating","laminating","embroidery","laser_cutting","digital_printing"]
  certifications    String?   // JSON array: ["oeko_tex_100","bluesign","gots","grs","iso_9001","iso_14001","wrap","bsci","sedex","higg"]
  fabricTypes       String?   // JSON array: ["jersey","interlock","pique","fleece","terry","mesh","rib","twill","poplin","satin","denim","nylon","polyester","cotton","blends","recycled"]
  moqMeters         Int?      // Minimum order quantity in meters
  leadTimeDays      Int?      // Typical lead time in days
  capacityMtMonth   Int?      // Monthly capacity in metric tons
  yearEstablished   Int?      // Year factory was established
  employeeCount     Int?      // Approximate headcount
  fuzeEnabled       Boolean?  // Has active FUZE treatment capability
  fuzeApplications  String?   // JSON array: ["bath_exhaust","spray_finish","jeanologia","wash_cycle","yarn_dye"]
  website           String?
  description       String?   // Free-text about the factory, searchable
  profileComplete   Boolean   @default(false)  // Whether discovery profile is filled out

  raw Json?

  // ─── Supply Chain: Default Distributor ─────────────
  distributorId String?
  distributor   Distributor? @relation("FactoryDistributor", fields: [distributorId], references: [id])

  salesRepId String?
  salesRep   User?  @relation("FactorySalesRep", fields: [salesRepId], references: [id])

  contacts      Contact[]
  brands        BrandFactory[]
  submissions   FabricSubmission[]
  fabrics       Fabric[]
  fuzeTestRequests FuzeTestRequest[] @relation("FuzeTestFactory")
  projects      Project[]      @relation("ProjectFactory")
  invoices      Invoice[]
  users         User[]         @relation("FactoryUsers")
  sourceRecords SourceRecord[]
  accessRequests AccessRequest[] @relation("AccessRequestFactory")
  sampleTrials   SampleTrialRequest[] @relation("FactoryTrials")
  distributorDocs DistributorDocument[] @relation("DistributorDocFactory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([country])
  @@index([profileComplete])
  @@index([distributorId])
}

model BrandFactory {
  id        String  @id @default(cuid())
  brandId   String
  factoryId String
  brand     Brand   @relation(fields: [brandId], references: [id])
  factory   Factory @relation(fields: [factoryId], references: [id])

  isPrimary Boolean @default(false)
  note      String?

  createdAt DateTime @default(now())

  @@unique([brandId, factoryId])
  @@index([brandId])
  @@index([factoryId])
}

// ─────────────────────────────────────────────
// DISTRIBUTORS
// ─────────────────────────────────────────────

model Distributor {
  id      String @id @default(cuid())
  name    String
  knackId String? @unique

  chineseName  String?
  specialty    String?
  agentForFuze String?
  annualSales  String?
  country      String?

  raw Json?

  contacts      Contact[]
  factories     Factory[]      @relation("FactoryDistributor")
  projects      Project[]      @relation("ProjectDistributor")
  invoices      Invoice[]
  documents     DistributorDocument[]
  users         User[]         @relation("DistributorUsers")
  sourceRecords SourceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// LABS
// ─────────────────────────────────────────────

model Lab {
  id      String @id @default(cuid())
  name    String @unique
  knackId String? @unique

  // Location
  address   String?
  city      String?
  state     String?
  country   String?
  region    String?   // "Asia Pacific", "North America", "Europe", etc.

  // Contact
  website   String?
  email     String?
  phone     String?

  // Capabilities & Certifications
  accreditations String?  // "ISO 17025, TAF, CNAS" etc.
  capabilities   String?  // Comma-separated: "ICP,ANTIBACTERIAL,FUNGAL,ODOR,UV"
  icpApproved    Boolean @default(false)
  abApproved     Boolean @default(false)
  fungalApproved Boolean @default(false)
  odorApproved   Boolean @default(false)
  uvApproved     Boolean @default(false)

  // Notes
  notes     String?
  active    Boolean @default(true)

  raw Json?

  // Customer account number at this lab
  customerNumber String?

  testRuns      TestRun[]
  testRequests  TestRequest[]
  sourceRecords SourceRecord[]
  services      LabService[]
  documents     Document[]
  shipments SampleShipment[] @relation("LabShipments")
  sampleTrials SampleTrialRequest[] @relation("TrialIcpLab")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([country])
  @@index([icpApproved])
}

// ─────────────────────────────────────────────
// LAB SERVICES & PRICING
// ─────────────────────────────────────────────

model LabService {
  id    String @id @default(cuid())
  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  testType      String   // "ICP", "ANTIBACTERIAL", "FUNGAL", "ODOR", "UV", "MICROFIBER", etc.
  testMethod    String?  // "AATCC 100", "ASTM E2149", "JIS L 1902", "ICP-OES", etc.
  description   String?  // e.g. "Antibacterial - AATCC 100 (S. aureus + K. pneumoniae)"
  priceUSD      Float?   // Our negotiated price per test
  listPriceUSD  Float?   // Lab's list price (before discount)
  turnaroundDays Int?    // Standard turnaround in business days
  rushPriceUSD  Float?   // Rush/expedited price
  rushDays      Int?     // Rush turnaround days
  notes         String?  // Special conditions, minimum qty, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([labId, testType, testMethod])
  @@index([labId])
}

// ─────────────────────────────────────────────
// CONTACTS
// ─────────────────────────────────────────────

model Contact {
  id String @id @default(cuid())

  title      String?
  firstName  String?
  middleName String?
  lastName   String?
  name       String?

  email   String?
  phone   String?
  address String?

  brandId       String?
  factoryId     String?
  distributorId String?

  brand       Brand?       @relation(fields: [brandId], references: [id])
  factory     Factory?     @relation(fields: [factoryId], references: [id])
  distributor Distributor? @relation(fields: [distributorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([factoryId])
}

// ─────────────────────────────────────────────
// FABRICS
// ─────────────────────────────────────────────

model Fabric {
  id String @id @default(cuid())

  fuzeNumber   Int?    @unique
  customerCode String?
  factoryCode  String?

  construction String?
  color        String?
  weightGsm    Float?
  widthInches  Float?
  yarnType     String?
  finishNote   String?
  note         String?

  brandId   String?
  factoryId String?
  brand     Brand?   @relation(fields: [brandId], references: [id])
  factory   Factory? @relation(fields: [factoryId], references: [id])

  raw Json?

  // Expanded fields (v2 intake form)
  endUse           String?    // Product type: t-shirt, athletic, bedding, etc.
  targetFuzeTier   String?    // F1, F2, F3, F4
  annualVolume     String?    // Estimated annual volume
  quantityType     String?    // ACTUAL, FORECAST, DEVELOPMENT, RD
  quantityUnit     String?    // meters, yards, kg
  batchLotNumber   String?    // Manufacturer batch/lot
  thickness        Float?     // mm
  shrinkageLength  Float?     // % shrinkage length
  shrinkageWidth   Float?     // % shrinkage width
  fabricCategory   String?    // woven, knit, nonwoven
  knitStitchType   String?    // jersey, rib, interlock, etc.
  weavePattern     String?    // plain, twill, satin, etc.
  gauge            String?    // knit gauge
  threadCountWarp  Int?
  threadCountWeft  Int?

  // Pretreatment
  pretreatment     Json?      // Full pretreatment data as JSON
  fabricPh         Float?     // pH after pretreatment

  // Dyeing
  dyeApplied       Boolean?
  dyeStage         String?    // yarn-dyed, piece-dyed, garment-dyed, greige
  dyeClass         String?    // reactive, disperse, acid, vat, etc.
  dyeDetails       Json?      // Full dye chemistry as JSON

  // Chemical finishes
  finishSoftener   Json?      // Softener details (type, ionic charge, concentration, etc.)
  finishRepellent  Json?      // Water repellent details
  finishWicking    Json?      // Moisture management details
  finishWrinkleFree Json?     // Easy-care finish details
  finishOther      Json?      // Other finishes (flame retardant, UV, anti-static, etc.)

  // Intake metadata
  intakeFormId     String?    // Reference to uploaded intake form
  intakeParsedAt   DateTime?  // When the intake form was parsed

  contents    FabricContent[]
  submissions FabricSubmission[]
  testRequests TestRequest[]
  fuzeTestRequests FuzeTestRequest[] @relation("FuzeTestFabric")
  sampleTrials     SampleTrialRequest[] @relation("FabricTrials")
  shipments SampleShipment[] @relation("FabricShipments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fuzeNumber])
  @@index([customerCode])
  @@index([factoryCode])
  @@index([brandId])
  @@index([factoryId])
}

model FabricContent {
  id       String @id @default(cuid())
  fabricId String
  fabric   Fabric @relation(fields: [fabricId], references: [id])

  material      String
  percent       Float?
  rawText       String?

  @@index([fabricId])
  @@index([material])
}

// ─────────────────────────────────────────────
// MATERIAL NORMALIZATION
// ─────────────────────────────────────────────

model MaterialAlias {
  id            String @id @default(cuid())
  alias         String @unique
  canonicalName String

  @@index([canonicalName])
}

// ─────────────────────────────────────────────
// FABRIC SUBMISSIONS (fabric + treatment context)
// ─────────────────────────────────────────────

model FabricSubmission {
  id String @id @default(cuid())

  brandId   String?
  factoryId String?
  fabricId  String?

  brand   Brand?   @relation(fields: [brandId], references: [id])
  factory Factory? @relation(fields: [factoryId], references: [id])
  fabric  Fabric?  @relation(fields: [fabricId], references: [id])

  fuzeFabricNumber   Int?
  customerFabricCode String?
  factoryFabricCode  String?

  applicationMethod    String?
  applicationRecipeRaw String?
  padRecipeRaw         String?
  treatmentLocation    String?
  applicationDate      DateTime?

  washTarget Int?

  status           String?
  programName      String?
  developmentStage String?
  testStatus       String?
  category         String?

  icpSent     Boolean?
  icpReceived Boolean?
  icpPassed   Boolean?

  abSent      Boolean?
  abReceived  Boolean?
  abPassed    Boolean?

  progressPercent Float?

  raw Json?

  testRuns      TestRun[]
  testRequests  TestRequest[]
  documents     Document[]
  sourceRecords SourceRecord[]
  shipments SampleShipment[] @relation("SubmissionShipments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fuzeFabricNumber])
  @@index([customerFabricCode])
  @@index([factoryFabricCode])
  @@index([status])
  @@index([testStatus])
}

// ─────────────────────────────────────────────
// PROJECTS (grouping tests under a brand)
// ─────────────────────────────────────────────

model Project {
  id      String @id @default(cuid())
  name    String
  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  description String?

  // ─── Commercial Pipeline Fields ─────────────
  stage              String    @default("DEVELOPMENT")  // DEVELOPMENT, SAMPLING, TESTING, APPROVED, COMMERCIALIZATION, PRODUCTION, COMPLETE
  projectedValue     Float?    // Projected annual revenue (USD or currency)
  actualValue        Float?    // Realized revenue from invoices
  currency           String    @default("USD")
  probability        Int       @default(50)             // Win probability 0-100
  fuzeTier           String?   // F1, F2, F3, F4
  annualVolumeMeters Float?    // Projected annual production volume in meters
  annualFuzeLiters   Float?    // Calculated: FUZE liters needed per year

  // ─── Manufacturing Assignment ─────────────
  factoryId     String?
  factory       Factory?     @relation("ProjectFactory", fields: [factoryId], references: [id])
  distributorId String?
  distributor   Distributor? @relation("ProjectDistributor", fields: [distributorId], references: [id])

  // ─── Timeline ─────────────
  expectedProductionDate DateTime?
  actualProductionDate   DateTime?

  testRuns     TestRun[]
  testRequests TestRequest[]
  invoices     Invoice[]
  meetings     Meeting[] @relation("MeetingProject")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, brandId])
  @@index([brandId])
  @@index([name])
  @@index([stage])
  @@index([factoryId])
  @@index([distributorId])
}

// ─────────────────────────────────────────────
// PRODUCTS / SKUs
// ─────────────────────────────────────────────

model Product {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  name        String
  productType String?
  sku         String?
  description String?

  sows SOWProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brandId, name])
  @@index([brandId])
  @@index([sku])
}

model SOWProduct {
  id        String  @id @default(cuid())
  sowId     String
  productId String
  sow       SOW     @relation(fields: [sowId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  note String?

  createdAt DateTime @default(now())

  @@unique([sowId, productId])
  @@index([sowId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// TEST RUNS & RESULTS
// ─────────────────────────────────────────────

model TestRun {
  id String @id @default(cuid())

  submissionId String?
  labId        String?
  projectId    String?

  submission FabricSubmission? @relation(fields: [submissionId], references: [id])
  lab        Lab?              @relation(fields: [labId], references: [id])
  project    Project?          @relation(fields: [projectId], references: [id])

  testNumber       Int?
  testType         TestType
  testMethodRaw    String?
  testMethodStd    String?
  testReportNumber String?
  fuzeInternalReportNumber String?
  postWashReportNumber     String?

  testDate     DateTime?
  postWashDate DateTime?

  washCount    Int?
  washLabelRaw String?

  machineType String?
  testedMetal String?

  agSerialNumber     String?
  auSerialNumber     String?
  fungalSerialNumber String?

  raw Json?

  // Multi-test PDF support
  testNumberInReport Int?      // Which test in a multi-test report (1, 2, ...)

  // AI review
  aiReviewData  Json?          // Merged anomaly review from dual-AI
  aiReviewDate  DateTime?
  aiReviewNotes String?        // Human-editable notes from AI flags

  // Brand visibility: only "stamped" tests visible to brand users
  brandVisible      Boolean  @default(false)
  brandApprovedById String?
  brandApprovedAt   DateTime?

  icpResult    IcpResult?
  abResult     AntibacterialResult?
  fungalResult FungalResult?
  odorResult   OdorResult?

  documents     Document[]
  sourceRecords SourceRecord[]
  testRequestLines TestRequestLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([testType])
  @@index([testMethodStd])
  @@index([washCount])
  @@index([testDate])
  @@index([submissionId])
  @@index([projectId])
}

model IcpResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  agValue Float?
  auValue Float?

  agRaw String?
  auRaw String?
  unit  String?
}

model AntibacterialResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  // Legacy fields (kept for backward compat with CSV imports)
  organism1    String?
  organism2    String?
  result1      Float?
  result2      Float?
  organism1Raw String?
  organism2Raw String?
  result1Raw   String?
  result2Raw   String?
  pass         Boolean?

  // ── Rich fields for ITS-style reports ──────────────────
  organism        String?   // "Staphylococcus aureus" or "Escherichia coli"
  strainNumber    String?   // "ATCC 6538" or "ATCC 25922"
  testMethodStd   String?   // "AATCC TM100-2019", "JIS L 1902:2015", "ASTM E2149-20"
  brothMedia      String?   // "Cation Adjusted Mueller Hinton Broth"
  surfactant      String?   // "0.05% Triton X-100"
  sterilization   String?   // "UV Sterilization" / "No Sterilization"
  contactTime     String?   // "24 Hours"
  incubationTemp  String?   // "37±2°C" / "35±2°C"
  agarMedium      String?   // "Nutrient Agar" / "Plate Count Agar"

  // Numeric results (method-dependent)
  inoculumCFU      Float?   // Starting inoculum concentration (CFU/mL)
  controlCFU       Float?   // Control bacteria after incubation
  treatedCFU       Float?   // Treated bacteria after incubation
  percentReduction Float?   // For AATCC TM100 & ASTM E2149
  growthValue      Float?   // F value (log growth)
  activityValue    Float?   // JIS L 1902 "A" value

  // Method-specific pass/fail
  methodPass       Boolean? // Per method thresholds
  methodPassReason String?  // "A=-0.2, requires A>=2.0 for Effect"

  // All extracted data as JSON (preserves everything the parser found)
  rawExtracted     Json?
}

model FungalResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  writtenResult String?
  pass          Boolean?
  raw           String?
}

model OdorResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  testedOdor String?
  result     String?
  pass       Boolean?
}

// ─────────────────────────────────────────────
// SOW (Scope of Work)
// ─────────────────────────────────────────────

model SOW {
  id      String    @id @default(cuid())
  brandId String
  brand   Brand     @relation(fields: [brandId], references: [id])

  title               String?
  expectations        String?
  performanceCriteria String?
  pricingTerms        String?
  costControls        String?

  signatory      String?
  signatoryTitle String?
  signatoryEmail String?

  status SOWStatus @default(DRAFT)

  milestones     SOWMilestone[]
  products       SOWProduct[]
  documents      Document[]
  accessRequests AccessRequest[]
  testRequests   TestRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
}

model SOWMilestone {
  id    String @id @default(cuid())
  sowId String
  sow   SOW    @relation(fields: [sowId], references: [id])

  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int       @default(0)

  @@index([sowId])
}

// ─────────────────────────────────────────────
// DOCUMENTS / ATTACHMENTS
// ─────────────────────────────────────────────

model Document {
  id String @id @default(cuid())

  kind        DocKind @default(REPORT)
  filename    String?
  contentType String?
  sizeBytes   Int?

  bucket String?
  key    String? @unique
  url    String?

  submissionId String?
  testRunId    String?
  sowId        String?
  labId        String?

  submission FabricSubmission? @relation(fields: [submissionId], references: [id])
  testRun    TestRun?          @relation(fields: [testRunId], references: [id])
  sow        SOW?              @relation(fields: [sowId], references: [id])
  lab        Lab?              @relation(fields: [labId], references: [id])

  raw Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submissionId])
  @@index([testRunId])
  @@index([sowId])
}

// ─────────────────────────────────────────────
// NOTES / ACTIVITY LOG
// ─────────────────────────────────────────────

model Note {
  id String @id @default(cuid())

  date     DateTime?
  content  String
  noteType String?

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  contactName String?
  taskStatus  String?

  createdAt DateTime @default(now())

  @@index([brandId])
  @@index([date])
}

// ─────────────────────────────────────────────
// INVOICES / REVENUE TRACKING
// ─────────────────────────────────────────────

model Invoice {
  id String @id @default(cuid())

  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime?
  paidDate      DateTime?
  amount        Float
  currency      String   @default("USD")
  status        String   @default("DRAFT")  // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  description   String?
  notes         String?

  // ─── Links ─────────────
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  factoryId     String
  factory       Factory     @relation(fields: [factoryId], references: [id])
  brandId       String?
  brand         Brand?      @relation(fields: [brandId], references: [id])
  projectId     String?
  project       Project?    @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([distributorId])
  @@index([factoryId])
  @@index([brandId])
  @@index([projectId])
  @@index([status])
  @@index([invoiceDate])
}

// ─────────────────────────────────────────────
// DISTRIBUTOR DOCUMENTS
// ─────────────────────────────────────────────

model DistributorDocument {
  id String @id @default(cuid())

  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])

  // Document classification
  docType     DistDocType  @default(OTHER)
  title       String                // "Certificate of Analysis - Batch 2024-03"
  description String?

  // File info
  filename    String?
  contentType String?
  sizeBytes   Int?
  url         String?               // S3/R2 URL or external link
  bucket      String?
  key         String?    @unique

  // Optional links to related entities
  factoryId   String?
  factory     Factory?   @relation("DistributorDocFactory", fields: [factoryId], references: [id])
  invoiceId   String?

  // Shipping/logistics metadata
  shipmentRef   String?             // tracking number or shipment ID
  batchNumber   String?             // production batch reference
  poNumber      String?             // purchase order
  portOfOrigin  String?
  portOfDest    String?
  hsCode        String?             // harmonized system code

  uploadedBy  String?               // user ID who uploaded
  expiresAt   DateTime?             // for time-sensitive docs like C of A

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([distributorId])
  @@index([docType])
  @@index([factoryId])
  @@index([createdAt])
}

enum DistDocType {
  CERTIFICATE_OF_ANALYSIS   // C of A
  BILL_OF_LADING            // BOL
  COMMERCIAL_INVOICE
  PACKING_LIST
  CUSTOMS_DECLARATION
  IMPORT_PERMIT
  EXPORT_PERMIT
  PHYTOSANITARY_CERT
  INSURANCE_CERT
  SDS_MSDS                  // Safety Data Sheet
  OTHER
}

// ─────────────────────────────────────────────
// BRAND PORTAL ACCESS REQUESTS
// ─────────────────────────────────────────────

model AccessRequest {
  id String @id @default(cuid())

  // Requester info
  firstName     String
  lastName      String
  email         String
  phone         String?
  jobTitle      String?
  company       String   // Brand / company name (or Factory/Mill name)
  website       String?

  // Request type
  requestType   String   @default("BRAND") // BRAND or FACTORY

  // Brand-specific fields
  fabricTypes    String?  // "Athletic, Hospitality, Medical" etc.
  annualVolume  String?  // "Under 100k meters", "100k-500k", "500k-1M", "Over 1M"
  timeline      String?  // "Immediate", "1-3 months", "3-6 months", "Exploratory"
  currentAntimicrobial String? // What they currently use
  notes         String?  // Anything else

  // Factory-specific fields
  factoryLocation  String?  // Country/city
  capabilities     String?  // JSON: ["knitting","weaving","dyeing","finishing"]
  certifications   String?  // "ISO 9001, OEKO-TEX, GOTS"
  productTypes     String?  // "Athletic, Denim, Medical" (can be same as fabricTypes for factory)
  monthlyCapacity  String?  // "Under 100k meters", "100k-500k", etc.
  fuzeApplicationMethod String? // "pad_exhaust", "spray", "wash_cycle", etc.

  // SOW reference (optional — linked when SOW exists)
  sowId         String?
  sow           SOW?     @relation(fields: [sowId], references: [id])

  // Processing
  status        String   @default("PENDING") // PENDING, APPROVED, DENIED, EXPIRED
  reviewedBy    String?  // User ID of reviewer
  reviewedAt    DateTime?
  reviewNote    String?
  deniedReason  String?

  // When approved, the created user
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])

  // When approved factory request, link to factory
  factoryId     String?
  factory       Factory? @relation("AccessRequestFactory", fields: [factoryId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([company])
  @@index([requestType])
}

// ─────────────────────────────────────────────
// TEST REQUESTS & APPROVAL WORKFLOW
// ─────────────────────────────────────────────

model TestRequest {
  id String @id @default(cuid())

  // Auto-generated PO number: FUZE-PO-YYYYMMDD-XXXX
  poNumber      String    @unique
  poDate        DateTime  @default(now())

  // What we're testing
  brandId       String?
  brand         Brand?    @relation("TestRequestBrand", fields: [brandId], references: [id])
  fabricId      String?
  fabric        Fabric?   @relation(fields: [fabricId], references: [id])
  submissionId  String?
  submission    FabricSubmission? @relation(fields: [submissionId], references: [id])
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  sowId         String?
  sow           SOW?      @relation(fields: [sowId], references: [id])

  // Where we're sending it
  labId         String
  lab           Lab       @relation(fields: [labId], references: [id])

  // Lab tracking
  labCustomerNumber String?   // Auto-filled from Lab.customerNumber
  labAccountRef     String?   // Additional reference for lab

  // Fabric identification on the PO
  fuzeFabricNumber  String?   // e.g. "FUZE-1042"
  customerFabricCode String?  // brand's code
  factoryFabricCode  String?  // factory's code

  // Status workflow: DRAFT → PENDING_APPROVAL → APPROVED → SUBMITTED → IN_PROGRESS → RESULTS_RECEIVED → COMPLETE → CANCELLED
  status        String    @default("DRAFT")

  // Approval
  requestedById String?
  requestedBy   User?     @relation("TestRequestRequester", fields: [requestedById], references: [id])
  requestedAt   DateTime?

  approvedById  String?
  approvedBy    User?     @relation("TestRequestApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  rejectedAt    DateTime?
  rejectedReason String?

  // Cost tracking
  estimatedCost Float?    // Sum of line items
  actualCost    Float?    // After invoice reconciliation
  currency      String    @default("USD")

  // Priority & scheduling
  priority      String    @default("NORMAL") // URGENT, HIGH, NORMAL, LOW
  requestedCompletionDate DateTime?
  actualCompletionDate    DateTime?

  // Notes & instructions
  specialInstructions String?  // Instructions for the lab
  internalNotes       String?  // Internal notes (not sent to lab)

  // Line items
  lines         TestRequestLine[]
  shipments SampleShipment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([brandId])
  @@index([labId])
  @@index([fabricId])
  @@index([projectId])
  @@index([requestedById])
  @@index([approvedById])
  @@index([poDate])
  @@index([priority])
}

model TestRequestLine {
  id String @id @default(cuid())

  testRequestId String
  testRequest   TestRequest @relation(fields: [testRequestId], references: [id], onDelete: Cascade)

  // Test details
  testType      String    // ICP, ANTIBACTERIAL, FUNGAL, ODOR, UV, MICROFIBER
  testMethod    String?   // AATCC 100, ASTM E2149, JIS L 1902, ICP-OES, etc.
  description   String?   // Additional description or wash count spec

  // Pricing (from LabService or manual)
  quantity      Int       @default(1)
  unitPrice     Float?    // USD per test
  totalPrice    Float?    // quantity × unitPrice
  rush          Boolean   @default(false)
  rushPrice     Float?    // Rush surcharge

  // Turnaround
  estimatedDays Int?      // Expected TAT from lab

  // Status per line
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETE, CANCELLED

  // Link back to actual test result when received
  testRunId     String?
  testRun       TestRun?  @relation(fields: [testRunId], references: [id])

  notes         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([testRequestId])
  @@index([testRunId])
  @@index([status])
}

// ─────────────────────────────────────────────
// FUZE TEST REQUESTS (Factory Portal)
// ─────────────────────────────────────────────

model FuzeTestRequest {
  id            String   @id @default(cuid())

  fabricId      String
  fabric        Fabric   @relation("FuzeTestFabric", fields: [fabricId], references: [id])

  factoryId     String?
  factory       Factory? @relation("FuzeTestFactory", fields: [factoryId], references: [id])

  requestedBy   String?  // User ID

  // Selected tests (JSON array of test IDs from catalog)
  selectedTests Json     // ["recipe-build", "antibacterial-screen"]

  // Requirements
  totalMoqMeters Float?
  controlRequired Boolean @default(false)

  // Shipping
  trackingNumber  String?
  shippedDate     DateTime?
  receivedDate    DateTime?

  // Status
  status         String   @default("PENDING") // PENDING, SAMPLES_REQUESTED, SAMPLES_RECEIVED, IN_PROGRESS, COMPLETED, CANCELLED

  notes          String?
  adminNotes     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([fabricId])
  @@index([factoryId])
  @@index([status])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id String @id @default(cuid())

  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id])

  type      String   // TEST_APPROVED, TEST_RESULTS, ACCESS_REQUEST, PO_STATUS, SOW_UPDATE, BRAND_ACTIVITY, SYSTEM
  title     String
  message   String
  link      String?  // URL to navigate to

  read      Boolean  @default(false)
  readAt    DateTime?

  metadata  Json?    // Extra context data

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([type])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id String @id @default(cuid())

  userId    String?
  user      User?    @relation("UserAuditLogs", fields: [userId], references: [id])

  action    String   // CREATE, UPDATE, DELETE, APPROVE, REJECT, LOGIN, EXPORT, STAMP
  entity    String   // Brand, Fabric, TestRequest, TestRun, SOW, User, AccessRequest
  entityId  String?

  description String
  changes     Json?    // { field: { old: x, new: y } }
  ipAddress   String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PASSWORD RESET
// ─────────────────────────────────────────────

model PasswordResetToken {
  id String @id @default(cuid())

  userId    String
  user      User    @relation("PasswordResets", fields: [userId], references: [id])

  token     String  @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────
// SAMPLE SHIPMENTS & TRACKING
// ─────────────────────────────────────────────

model SampleShipment {
  id String @id @default(cuid())

  // What's being shipped
  fabricId      String?
  fabric        Fabric?  @relation("FabricShipments", fields: [fabricId], references: [id])
  submissionId  String?
  submission    FabricSubmission? @relation("SubmissionShipments", fields: [submissionId], references: [id])
  testRequestId String?
  testRequest   TestRequest? @relation(fields: [testRequestId], references: [id])

  // Where
  originName    String?   // "FUZE Lab Shanghai"
  originAddress String?
  destinationName    String?  // Lab name or factory
  destinationAddress String?

  labId         String?
  lab           Lab?     @relation("LabShipments", fields: [labId], references: [id])

  // Shipping details
  carrier       String?   // FedEx, DHL, UPS, SF Express, local courier
  trackingNumber String?
  shipDate      DateTime?
  estimatedArrival DateTime?
  actualArrival   DateTime?

  // Sample details
  sampleCount   Int       @default(1)
  sampleType    String?   // "Fabric swatch", "Treated sample", "Washed sample"
  sampleCondition String? // "Good", "Damaged", "Sealed"
  weight        Float?    // kg

  // Status: PREPARING → SHIPPED → IN_TRANSIT → DELIVERED → AT_LAB → RETURNED
  status        String    @default("PREPARING")

  // Chain of custody
  events        ShipmentEvent[]

  notes         String?

  createdBy     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([trackingNumber])
  @@index([fabricId])
  @@index([labId])
  @@index([testRequestId])
}

model ShipmentEvent {
  id String @id @default(cuid())

  shipmentId String
  shipment   SampleShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  eventType  String    // CREATED, PICKED_UP, IN_TRANSIT, CUSTOMS, DELIVERED, RECEIVED_AT_LAB, CONDITION_NOTE, RETURNED
  location   String?
  handler    String?   // Person name
  notes      String?
  photoUrl   String?   // Optional photo of sample condition

  createdAt  DateTime  @default(now())

  @@index([shipmentId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// FABRIC RECIPE LIBRARY
// ─────────────────────────────────────────────

model FabricRecipe {
  id String @id @default(cuid())

  name          String    // "Cotton 180GSM Pad Application F2"

  // Fabric characteristics this recipe applies to
  fabricType    String?   // "Knit", "Woven", "Nonwoven"
  fiberContent  String?   // "100% Cotton", "65/35 Poly-Cotton", etc.
  gsmMin        Float?    // GSM range this recipe works for
  gsmMax        Float?
  yarnType      String?

  // Treatment parameters
  fuzeTier      String?   // F1, F2, F3, F4
  applicationMethod String? // "Pad", "Exhaust", "Spray", "Foam"
  padPickupPercent  Float?  // Pad pickup %
  bathConcentration Float?  // g/L or ppm
  squeezePressure   Float?  // bar/psi
  dryingTemp        Float?  // Celsius
  dryingTime        Float?  // minutes
  curingTemp        Float?  // Celsius
  curingTime        Float?  // minutes
  phRange           String? // "4.5-5.5"

  // Results achieved
  avgIcpAg      Float?    // Average silver ppm from tests
  avgReduction  Float?    // Average % reduction from AB tests
  testMethod    String?   // "AATCC 100", "ASTM E2149"
  passRate      Float?    // % of tests that passed

  // Linked test runs that validated this recipe
  validatedTestCount Int @default(0)

  notes         String?
  active        Boolean   @default(true)

  createdById   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([fabricType])
  @@index([fiberContent])
  @@index([fuzeTier])
  @@index([applicationMethod])
}

// ─────────────────────────────────────────────
// CURRENCY & EXCHANGE RATES
// ─────────────────────────────────────────────

model ExchangeRate {
  id String @id @default(cuid())

  fromCurrency String   // "USD"
  toCurrency   String   // "CNY"
  rate         Float    // 1 USD = X CNY
  source       String?  // "manual", "api", "bank"

  effectiveDate DateTime

  createdAt DateTime @default(now())

  @@unique([fromCurrency, toCurrency, effectiveDate])
  @@index([fromCurrency, toCurrency])
  @@index([effectiveDate])
}

// ─────────────────────────────────────────────
// BRAND ENGAGEMENT SCORING
// ─────────────────────────────────────────────

model BrandEngagement {
  id String @id @default(cuid())

  brandId     String    @unique
  brand       Brand     @relation("BrandEngagement", fields: [brandId], references: [id])

  // Scores (0-100)
  overallScore     Int   @default(50)
  communicationScore Int @default(50)  // Days since last note/contact
  testingVelocity   Int @default(50)  // Tests completed per month
  pipelineVelocity  Int @default(50)  // Speed moving through stages
  paymentScore      Int @default(50)  // Invoice payment timeliness
  engagementTrend   String @default("STABLE") // RISING, STABLE, DECLINING, AT_RISK

  // Raw metrics
  daysSinceLastContact Int?
  testsLast30Days      Int @default(0)
  testsLast90Days      Int @default(0)
  avgInvoicePayDays    Float?
  overdueInvoices      Int @default(0)
  stageChanges90Days   Int @default(0)

  lastCalculated DateTime @default(now())

  @@index([overallScore])
  @@index([engagementTrend])
}

// ─────────────────────────────────────────────
// MEETINGS / CALENDAR
// ─────────────────────────────────────────────

model Meeting {
  id String @id @default(cuid())

  title       String
  description String?
  meetingType String    @default("INTERNAL")   // INTERNAL, BRAND_PRESENTATION, TESTING_REVIEW, FACTORY_KICKOFF, PRODUCTION_REVIEW, SOW_REVIEW, CUSTOM

  // Schedule
  startTime   DateTime
  endTime     DateTime
  timezone    String    @default("Asia/Taipei")
  location    String?                           // Physical location or "Microsoft Teams" / "Zoom"
  teamsLink   String?                           // Auto-generated Teams deep link
  calendarUrl String?                           // .ics download URL

  // Relations
  brandId   String?
  brand     Brand?   @relation("MeetingBrand", fields: [brandId], references: [id])
  projectId String?
  project   Project? @relation("MeetingProject", fields: [projectId], references: [id])

  // Pipeline trigger
  pipelineStage String?                         // Which stage triggered this meeting
  autoScheduled Boolean @default(false)         // Was this auto-created by pipeline movement?

  // Organizer & attendees stored as JSON
  organizerId String?
  organizer   User?    @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  attendees   Json?                             // [{name, email, role}]

  status    String   @default("SCHEDULED")      // SCHEDULED, COMPLETED, CANCELLED, RESCHEDULED
  notes     String?                             // Post-meeting notes
  outcome   String?                             // Meeting outcome summary

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([brandId])
  @@index([projectId])
  @@index([status])
  @@index([meetingType])
}

// ─────────────────────────────────────────────
// AVAILABILITY CONFIG (for self-booking system)
// ─────────────────────────────────────────────

model AvailabilityConfig {
  id                    String   @id @default("default")
  availableDays         Json     @default("[2,4]")                    // 0=Sunday, 2=Tuesday, 4=Thursday, etc
  startHour             Int      @default(9)                          // 9 = 9 AM
  endHour               Int      @default(17)                         // 5 PM
  slotDurationMinutes   Int      @default(60)
  timezone              String   @default("Asia/Taipei")
  blockedDates          Json     @default("[]")                       // ISO date strings
  maxBookingsPerDay     Int      @default(3)
  updatedAt             DateTime @updatedAt
}

// ─────────────────────────────────────────────
// COMPLIANCE LIBRARY — SDS, TDS, Bluesign, ZDHC, Oeko-Tex, GOTS
// ─────────────────────────────────────────────

model ComplianceDocument {
  id String @id @default(cuid())

  title       String
  description String?
  category    String   @default("OTHER") // Flexible string categories (SDS_MSDS, TDS, BLUESIGN, ZDHC, OEKO_TEX, GOTS, EPA, REACH, COA, COC, ISO, IMPORT_EXPORT, OTHER, or custom)
  version     String?
  filename    String?
  contentType String?
  sizeBytes   Int?
  url         String?
  data        String?            // base64 data URL for inline storage (legacy — prefer S3)
  s3Key       String?            // S3 object key for files uploaded via presigned URL

  // Role-based visibility: JSON array of role strings e.g. ["ADMIN","BRAND_USER","FACTORY_USER"]
  // If empty/null, only ADMIN can see it
  visibleTo Json @default("[\"ADMIN\",\"EMPLOYEE\",\"BRAND_USER\",\"FACTORY_USER\",\"FACTORY_MANAGER\"]")

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([uploadedById])
}

// ─────────────────────────────────────────────
// SAMPLE TRIAL REQUESTS
// Factory requests FUZE product sample for trial application
// ─────────────────────────────────────────────

model SampleTrialRequest {
  id                  String   @id @default(cuid())

  // Who's requesting
  factoryId           String
  factory             Factory  @relation("FactoryTrials", fields: [factoryId], references: [id])
  requestedById       String
  requestedBy         User     @relation("TrialRequester", fields: [requestedById], references: [id])

  // What fabric (must exist — if not, factory submits fabric first)
  fabricId            String
  fabric              Fabric   @relation("FabricTrials", fields: [fabricId], references: [id])

  // For whom — brand partnership or self-development
  purposeType         String   // BRAND_PARTNERSHIP | SELF_DEVELOPMENT
  brandId             String?
  brand               Brand?   @relation("TrialBrand", fields: [brandId], references: [id])
  partnershipNote     String?  // Free text if brand not in system yet

  // Trial details
  trialType           String   // LAB_TRIAL | PRODUCTION_TRIAL
  totalMeters         Float    // Total fabric meters/yards to be treated
  totalUnit           String   @default("meters") // meters | yards
  targetFuzeTier      String?  // F1, F2, F3, F4
  applicationMethod   String?  // exhaust | pad | spray

  // FUZE sample shipment
  sampleVolumeLiters  Float?   // Calculated from fabric params + tier
  shippingAddress     String?  // Factory address for sample delivery
  shippingCity        String?
  shippingState       String?
  shippingPostalCode  String?
  shippingCountry     String?
  shippingContactName String?
  shippingContactPhone String?
  shippingContactEmail String?

  // Shipping account — factory pays freight on US-origin samples
  shippingCarrier       String?  // FedEx, DHL, UPS, etc.
  shippingAccountNumber String?  // Their carrier account number for billing
  shippingMethod        String?  // EXPRESS | STANDARD | ECONOMY
  shippingOrigin        String?  @default("US") // US = ships from FUZE USA, DISTRIBUTOR = in-country
  shippingNotes         String?  // Special instructions, broker info, customs notes

  // ICP Lab commitment (mandatory)
  icpLabId            String?
  icpLab              Lab?     @relation("TrialIcpLab", fields: [icpLabId], references: [id])
  icpLabOther         String?  // If lab not yet in system
  icpCommitDate       DateTime? // When they commit to send for ICP testing

  // Status workflow
  // SUBMITTED → UNDER_REVIEW → APPROVED → SAMPLE_SHIPPED →
  // SAMPLE_RECEIVED → TRIAL_IN_PROGRESS → ICP_PENDING →
  // ICP_SUBMITTED → COMPLETE  (or REJECTED at any point)
  status              String   @default("SUBMITTED")

  // Admin tracking
  approvedById        String?
  approvedAt          DateTime?
  rejectedReason      String?
  sampleTrackingNumber String?
  sampleShippedDate   DateTime?
  sampleReceivedDate  DateTime?

  // ICP follow-up
  icpTestRunId        String?  // Links to actual ICP TestRun when results submitted
  icpSubmittedAt      DateTime?
  icpAgValue          Float?   // Quick-reference Ag result
  icpAuValue          Float?   // Quick-reference Au result

  notes               String?
  adminNotes          String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([factoryId])
  @@index([fabricId])
  @@index([brandId])
  @@index([status])
  @@index([icpLabId])
}

// ─────────────────────────────────────────────
// API CALL AUDIT LOG
// ─────────────────────────────────────────────

model ApiCallLog {
  id          String   @id @default(cuid())
  provider    String   // "openai" | "anthropic"
  callerRoute String   // "chat" | "research" | "test-review" | "fabric-intake"
  userId      String?  // from x-user-id header (who triggered it)
  statusCode  Int      // HTTP status from the AI API
  durationMs  Int      // how long the call took
  attempt     Int      @default(0) // retry attempt number
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([provider])
  @@index([statusCode])
}