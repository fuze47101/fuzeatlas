generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum SourceSystem {
  KNACK
  CSV
  MANUAL
  API
}

enum PipelineStage {
  LEAD
  PRESENTATION
  BRAND_TESTING
  FACTORY_ONBOARDING
  FACTORY_TESTING
  PRODUCTION
  BRAND_EXPANSION
  ARCHIVE
  CUSTOMER_WON
}

enum TestType {
  ICP
  ANTIBACTERIAL
  FUNGAL
  ODOR
  UV
  MICROFIBER
  OTHER
}

enum TestStatus {
  REQUESTED
  IN_PROGRESS
  PASSED
  FAILED
  RETEST
  PASSED_COMPLETE
}

enum DocKind {
  REPORT
  IMAGE
  SUBMISSION_DOC
  SOW_DOC
  OTHER
}

enum SOWStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  COMPLETE
  CANCELLED
}

enum UserRole {
  ADMIN
  EMPLOYEE
  SALES_MANAGER
  SALES_REP
  FABRIC_MANAGER
  TESTING_MANAGER
  FACTORY_MANAGER
  FACTORY_USER
  BRAND_USER
  DISTRIBUTOR_USER
  PUBLIC
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

// ─────────────────────────────────────────────
// COMPETITOR PRICE OVERRIDES (admin espionage data)
// ─────────────────────────────────────────────

model CompetitorPriceOverride {
  id              String  @id @default(cuid())
  competitorId    String  @unique  // matches id from COMPETITORS array in competitors.ts

  // Distributor pricing (real espionage data from China distributors etc.)
  chemicalPricePerKg         Float?   // USD/kg of antimicrobial as purchased
  chemicalPriceSource        String?  // "China distributor quote", "India contact", etc.
  chemicalPriceDate          DateTime? // when the price was obtained

  // Binder pricing overrides
  binderPricePerKg           Float?   // USD/kg of binder chemical

  // Application cost overrides (per linear meter)
  estimatedCostPerMeterLow      Float?
  estimatedCostPerMeterHigh     Float?
  estimatedCostPerMeterTypical  Float?

  // Re-treatment multiplier override
  retreatmentCostMultiplier  Float?

  // Notes
  notes          String?  // free-form notes about the source, confidence, etc.

  updatedBy      String?  // user name who last updated
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([competitorId])
}

// ─────────────────────────────────────────────
// AUDIT / IMPORT TRACKING
// ─────────────────────────────────────────────

model SourceRecord {
  id             String       @id @default(cuid())
  sourceSystem   SourceSystem @default(CSV)
  sourceTable    String
  sourceRecordId String?
  sourceKey      String?
  raw            Json
  importedAt     DateTime     @default(now())

  brandId      String?
  factoryId    String?
  labId        String?
  submissionId String?
  testRunId      String?
  distributorId  String?

  brand      Brand?            @relation(fields: [brandId], references: [id])
  factory    Factory?          @relation(fields: [factoryId], references: [id])
  lab        Lab?              @relation(fields: [labId], references: [id])
  submission FabricSubmission? @relation(fields: [submissionId], references: [id])
  testRun    TestRun?          @relation(fields: [testRunId], references: [id])
  distributor Distributor?      @relation(fields: [distributorId], references: [id])

  @@index([sourceSystem, sourceTable])
  @@index([sourceRecordId])
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id       String     @id @default(cuid())
  name     String
  email    String     @unique
  password String?
  role     UserRole   @default(PUBLIC)
  status   UserStatus @default(ACTIVE)

  salesManagerId String?
  salesManager   User?   @relation("SalesManagerReps", fields: [salesManagerId], references: [id])
  managedReps    User[]  @relation("SalesManagerReps")

  brandId       String?
  brand         Brand?       @relation("BrandUsers", fields: [brandId], references: [id])
  factoryId     String?
  factory       Factory?     @relation("FactoryUsers", fields: [factoryId], references: [id])
  distributorId String?
  distributor   Distributor? @relation("DistributorUsers", fields: [distributorId], references: [id])

  assignedBrands    Brand[]    @relation("BrandSalesRep")
  assignedFactories Factory[]  @relation("FactorySalesRep")

  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([email])
}

// ─────────────────────────────────────────────
// BRANDS / CUSTOMERS
// ─────────────────────────────────────────────

model Brand {
  id     String @id @default(cuid())
  name   String @unique
  knackId String? @unique

  pipelineStage      PipelineStage @default(LEAD)
  customerType       String?
  leadReferralSource String?
  dateOfInitialContact DateTime?

  website        String?
  linkedInProfile String?
  backgroundInfo String?
  researchData   Json?
  researchDate   DateTime?

  projectType        String?
  projectDescription String?
  presentationDate   DateTime?
  forecast           String?
  deliverables       String?

  raw Json?

  salesRepId String?
  salesRep   User?  @relation("BrandSalesRep", fields: [salesRepId], references: [id])

  contacts    Contact[]
  factories   BrandFactory[]
  submissions FabricSubmission[]
  fabrics     Fabric[]
  projects    Project[]
  products    Product[]
  sows        SOW[]
  invoices    Invoice[]
  notes       Note[]
  users       User[]         @relation("BrandUsers")
  sourceRecords SourceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineStage])
  @@index([name])
}

// ─────────────────────────────────────────────
// FACTORIES / TEXTILE MILLS
// ─────────────────────────────────────────────

model Factory {
  id      String @id @default(cuid())
  name    String
  knackId String? @unique

  chineseName  String?
  millType     String?
  specialty    String?
  purchasing   String?
  annualSales  String?

  address          String?
  city             String?
  state            String?
  country          String?
  secondaryCountry String?

  development          String?
  presentationComplete Boolean?
  customerType         String?
  brandNominated       String?

  // ─── Searchable / Discovery Fields ─────────────
  productTypes      String?   // JSON array: ["activewear","denim","intimates","socks","wovens","knits","outerwear","home_textiles","non_woven","medical","industrial"]
  capabilities      String?   // JSON array: ["dyeing","finishing","printing","knitting","weaving","cut_sew","coating","laminating","embroidery","laser_cutting","digital_printing"]
  certifications    String?   // JSON array: ["oeko_tex_100","bluesign","gots","grs","iso_9001","iso_14001","wrap","bsci","sedex","higg"]
  fabricTypes       String?   // JSON array: ["jersey","interlock","pique","fleece","terry","mesh","rib","twill","poplin","satin","denim","nylon","polyester","cotton","blends","recycled"]
  moqMeters         Int?      // Minimum order quantity in meters
  leadTimeDays      Int?      // Typical lead time in days
  capacityMtMonth   Int?      // Monthly capacity in metric tons
  yearEstablished   Int?      // Year factory was established
  employeeCount     Int?      // Approximate headcount
  fuzeEnabled       Boolean?  // Has active FUZE treatment capability
  fuzeApplications  String?   // JSON array: ["bath_exhaust","spray_finish","jeanologia","wash_cycle","yarn_dye"]
  website           String?
  description       String?   // Free-text about the factory, searchable
  profileComplete   Boolean   @default(false)  // Whether discovery profile is filled out

  raw Json?

  // ─── Supply Chain: Default Distributor ─────────────
  distributorId String?
  distributor   Distributor? @relation("FactoryDistributor", fields: [distributorId], references: [id])

  salesRepId String?
  salesRep   User?  @relation("FactorySalesRep", fields: [salesRepId], references: [id])

  contacts      Contact[]
  brands        BrandFactory[]
  submissions   FabricSubmission[]
  fabrics       Fabric[]
  projects      Project[]      @relation("ProjectFactory")
  invoices      Invoice[]
  users         User[]         @relation("FactoryUsers")
  sourceRecords SourceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([country])
  @@index([profileComplete])
  @@index([distributorId])
}

model BrandFactory {
  id        String  @id @default(cuid())
  brandId   String
  factoryId String
  brand     Brand   @relation(fields: [brandId], references: [id])
  factory   Factory @relation(fields: [factoryId], references: [id])

  isPrimary Boolean @default(false)
  note      String?

  createdAt DateTime @default(now())

  @@unique([brandId, factoryId])
  @@index([brandId])
  @@index([factoryId])
}

// ─────────────────────────────────────────────
// DISTRIBUTORS
// ─────────────────────────────────────────────

model Distributor {
  id      String @id @default(cuid())
  name    String
  knackId String? @unique

  chineseName  String?
  specialty    String?
  agentForFuze String?
  annualSales  String?
  country      String?

  raw Json?

  contacts      Contact[]
  factories     Factory[]      @relation("FactoryDistributor")
  projects      Project[]      @relation("ProjectDistributor")
  invoices      Invoice[]
  users         User[]         @relation("DistributorUsers")
  sourceRecords SourceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// LABS
// ─────────────────────────────────────────────

model Lab {
  id      String @id @default(cuid())
  name    String @unique
  knackId String? @unique

  // Location
  address   String?
  city      String?
  state     String?
  country   String?
  region    String?   // "Asia Pacific", "North America", "Europe", etc.

  // Contact
  website   String?
  email     String?
  phone     String?

  // Capabilities & Certifications
  accreditations String?  // "ISO 17025, TAF, CNAS" etc.
  capabilities   String?  // Comma-separated: "ICP,ANTIBACTERIAL,FUNGAL,ODOR,UV"
  icpApproved    Boolean @default(false)
  abApproved     Boolean @default(false)
  fungalApproved Boolean @default(false)
  odorApproved   Boolean @default(false)
  uvApproved     Boolean @default(false)

  // Notes
  notes     String?
  active    Boolean @default(true)

  raw Json?

  testRuns      TestRun[]
  sourceRecords SourceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([country])
  @@index([icpApproved])
}

// ─────────────────────────────────────────────
// CONTACTS
// ─────────────────────────────────────────────

model Contact {
  id String @id @default(cuid())

  title      String?
  firstName  String?
  middleName String?
  lastName   String?
  name       String?

  email   String?
  phone   String?
  address String?

  brandId       String?
  factoryId     String?
  distributorId String?

  brand       Brand?       @relation(fields: [brandId], references: [id])
  factory     Factory?     @relation(fields: [factoryId], references: [id])
  distributor Distributor? @relation(fields: [distributorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([factoryId])
}

// ─────────────────────────────────────────────
// FABRICS
// ─────────────────────────────────────────────

model Fabric {
  id String @id @default(cuid())

  fuzeNumber   Int?    @unique
  customerCode String?
  factoryCode  String?

  construction String?
  color        String?
  weightGsm    Float?
  widthInches  Float?
  yarnType     String?
  finishNote   String?
  note         String?

  brandId   String?
  factoryId String?
  brand     Brand?   @relation(fields: [brandId], references: [id])
  factory   Factory? @relation(fields: [factoryId], references: [id])

  raw Json?

  contents    FabricContent[]
  submissions FabricSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fuzeNumber])
  @@index([customerCode])
  @@index([factoryCode])
  @@index([brandId])
  @@index([factoryId])
}

model FabricContent {
  id       String @id @default(cuid())
  fabricId String
  fabric   Fabric @relation(fields: [fabricId], references: [id])

  material      String
  percent       Float?
  rawText       String?

  @@index([fabricId])
  @@index([material])
}

// ─────────────────────────────────────────────
// MATERIAL NORMALIZATION
// ─────────────────────────────────────────────

model MaterialAlias {
  id            String @id @default(cuid())
  alias         String @unique
  canonicalName String

  @@index([canonicalName])
}

// ─────────────────────────────────────────────
// FABRIC SUBMISSIONS (fabric + treatment context)
// ─────────────────────────────────────────────

model FabricSubmission {
  id String @id @default(cuid())

  brandId   String?
  factoryId String?
  fabricId  String?

  brand   Brand?   @relation(fields: [brandId], references: [id])
  factory Factory? @relation(fields: [factoryId], references: [id])
  fabric  Fabric?  @relation(fields: [fabricId], references: [id])

  fuzeFabricNumber   Int?
  customerFabricCode String?
  factoryFabricCode  String?

  applicationMethod    String?
  applicationRecipeRaw String?
  padRecipeRaw         String?
  treatmentLocation    String?
  applicationDate      DateTime?

  washTarget Int?

  status           String?
  programName      String?
  developmentStage String?
  testStatus       String?
  category         String?

  icpSent     Boolean?
  icpReceived Boolean?
  icpPassed   Boolean?

  abSent      Boolean?
  abReceived  Boolean?
  abPassed    Boolean?

  progressPercent Float?

  raw Json?

  testRuns      TestRun[]
  documents     Document[]
  sourceRecords SourceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fuzeFabricNumber])
  @@index([customerFabricCode])
  @@index([factoryFabricCode])
  @@index([status])
  @@index([testStatus])
}

// ─────────────────────────────────────────────
// PROJECTS (grouping tests under a brand)
// ─────────────────────────────────────────────

model Project {
  id      String @id @default(cuid())
  name    String
  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  description String?

  // ─── Commercial Pipeline Fields ─────────────
  stage              String    @default("DEVELOPMENT")  // DEVELOPMENT, SAMPLING, TESTING, APPROVED, COMMERCIALIZATION, PRODUCTION, COMPLETE
  projectedValue     Float?    // Projected annual revenue (USD or currency)
  actualValue        Float?    // Realized revenue from invoices
  currency           String    @default("USD")
  probability        Int       @default(50)             // Win probability 0-100
  fuzeTier           String?   // F1, F2, F3, F4
  annualVolumeMeters Float?    // Projected annual production volume in meters
  annualFuzeLiters   Float?    // Calculated: FUZE liters needed per year

  // ─── Manufacturing Assignment ─────────────
  factoryId     String?
  factory       Factory?     @relation("ProjectFactory", fields: [factoryId], references: [id])
  distributorId String?
  distributor   Distributor? @relation("ProjectDistributor", fields: [distributorId], references: [id])

  // ─── Timeline ─────────────
  expectedProductionDate DateTime?
  actualProductionDate   DateTime?

  testRuns TestRun[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, brandId])
  @@index([brandId])
  @@index([name])
  @@index([stage])
  @@index([factoryId])
  @@index([distributorId])
}

// ─────────────────────────────────────────────
// PRODUCTS / SKUs
// ─────────────────────────────────────────────

model Product {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  name        String
  productType String?
  sku         String?
  description String?

  sows SOWProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brandId, name])
  @@index([brandId])
  @@index([sku])
}

model SOWProduct {
  id        String  @id @default(cuid())
  sowId     String
  productId String
  sow       SOW     @relation(fields: [sowId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  note String?

  createdAt DateTime @default(now())

  @@unique([sowId, productId])
  @@index([sowId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// TEST RUNS & RESULTS
// ─────────────────────────────────────────────

model TestRun {
  id String @id @default(cuid())

  submissionId String?
  labId        String?
  projectId    String?

  submission FabricSubmission? @relation(fields: [submissionId], references: [id])
  lab        Lab?              @relation(fields: [labId], references: [id])
  project    Project?          @relation(fields: [projectId], references: [id])

  testNumber       Int?
  testType         TestType
  testMethodRaw    String?
  testMethodStd    String?
  testReportNumber String?
  fuzeInternalReportNumber String?
  postWashReportNumber     String?

  testDate     DateTime?
  postWashDate DateTime?

  washCount    Int?
  washLabelRaw String?

  machineType String?
  testedMetal String?

  agSerialNumber     String?
  auSerialNumber     String?
  fungalSerialNumber String?

  raw Json?

  // Multi-test PDF support
  testNumberInReport Int?      // Which test in a multi-test report (1, 2, ...)

  // AI review
  aiReviewData  Json?          // Merged anomaly review from dual-AI
  aiReviewDate  DateTime?
  aiReviewNotes String?        // Human-editable notes from AI flags

  icpResult    IcpResult?
  abResult     AntibacterialResult?
  fungalResult FungalResult?
  odorResult   OdorResult?

  documents     Document[]
  sourceRecords SourceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([testType])
  @@index([testMethodStd])
  @@index([washCount])
  @@index([testDate])
  @@index([submissionId])
  @@index([projectId])
}

model IcpResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  agValue Float?
  auValue Float?

  agRaw String?
  auRaw String?
  unit  String?
}

model AntibacterialResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  // Legacy fields (kept for backward compat with CSV imports)
  organism1    String?
  organism2    String?
  result1      Float?
  result2      Float?
  organism1Raw String?
  organism2Raw String?
  result1Raw   String?
  result2Raw   String?
  pass         Boolean?

  // ── Rich fields for ITS-style reports ──────────────────
  organism        String?   // "Staphylococcus aureus" or "Escherichia coli"
  strainNumber    String?   // "ATCC 6538" or "ATCC 25922"
  testMethodStd   String?   // "AATCC TM100-2019", "JIS L 1902:2015", "ASTM E2149-20"
  brothMedia      String?   // "Cation Adjusted Mueller Hinton Broth"
  surfactant      String?   // "0.05% Triton X-100"
  sterilization   String?   // "UV Sterilization" / "No Sterilization"
  contactTime     String?   // "24 Hours"
  incubationTemp  String?   // "37±2°C" / "35±2°C"
  agarMedium      String?   // "Nutrient Agar" / "Plate Count Agar"

  // Numeric results (method-dependent)
  inoculumCFU      Float?   // Starting inoculum concentration (CFU/mL)
  controlCFU       Float?   // Control bacteria after incubation
  treatedCFU       Float?   // Treated bacteria after incubation
  percentReduction Float?   // For AATCC TM100 & ASTM E2149
  growthValue      Float?   // F value (log growth)
  activityValue    Float?   // JIS L 1902 "A" value

  // Method-specific pass/fail
  methodPass       Boolean? // Per method thresholds
  methodPassReason String?  // "A=-0.2, requires A>=2.0 for Effect"

  // All extracted data as JSON (preserves everything the parser found)
  rawExtracted     Json?
}

model FungalResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  writtenResult String?
  pass          Boolean?
  raw           String?
}

model OdorResult {
  id        String  @id @default(cuid())
  testRunId String  @unique
  testRun   TestRun @relation(fields: [testRunId], references: [id])

  testedOdor String?
  result     String?
  pass       Boolean?
}

// ─────────────────────────────────────────────
// SOW (Scope of Work)
// ─────────────────────────────────────────────

model SOW {
  id      String    @id @default(cuid())
  brandId String
  brand   Brand     @relation(fields: [brandId], references: [id])

  title               String?
  expectations        String?
  performanceCriteria String?
  pricingTerms        String?
  costControls        String?

  signatory      String?
  signatoryTitle String?
  signatoryEmail String?

  status SOWStatus @default(DRAFT)

  milestones SOWMilestone[]
  products   SOWProduct[]
  documents  Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
}

model SOWMilestone {
  id    String @id @default(cuid())
  sowId String
  sow   SOW    @relation(fields: [sowId], references: [id])

  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int       @default(0)

  @@index([sowId])
}

// ─────────────────────────────────────────────
// DOCUMENTS / ATTACHMENTS
// ─────────────────────────────────────────────

model Document {
  id String @id @default(cuid())

  kind        DocKind @default(REPORT)
  filename    String?
  contentType String?
  sizeBytes   Int?

  bucket String?
  key    String? @unique
  url    String?

  submissionId String?
  testRunId    String?
  sowId        String?

  submission FabricSubmission? @relation(fields: [submissionId], references: [id])
  testRun    TestRun?          @relation(fields: [testRunId], references: [id])
  sow        SOW?              @relation(fields: [sowId], references: [id])

  raw Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submissionId])
  @@index([testRunId])
  @@index([sowId])
}

// ─────────────────────────────────────────────
// NOTES / ACTIVITY LOG
// ─────────────────────────────────────────────

model Note {
  id String @id @default(cuid())

  date     DateTime?
  content  String
  noteType String?

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  contactName String?
  taskStatus  String?

  createdAt DateTime @default(now())

  @@index([brandId])
  @@index([date])
}

// ─────────────────────────────────────────────
// INVOICES / REVENUE TRACKING
// ─────────────────────────────────────────────

model Invoice {
  id String @id @default(cuid())

  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime?
  paidDate      DateTime?
  amount        Float
  currency      String   @default("USD")
  status        String   @default("DRAFT")  // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  description   String?
  notes         String?

  // ─── Links ─────────────
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  factoryId     String
  factory       Factory     @relation(fields: [factoryId], references: [id])
  brandId       String?
  brand         Brand?      @relation(fields: [brandId], references: [id])
  projectId     String?
  project       Project?    @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([distributorId])
  @@index([factoryId])
  @@index([brandId])
  @@index([projectId])
  @@index([status])
  @@index([invoiceDate])
}