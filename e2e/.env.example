# Playwright Test Environment Configuration

# Base URL for the application
# Local development
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Or for testing against staging
# PLAYWRIGHT_BASE_URL=https://staging.fuzeatlas.com

# Or for testing against production
# PLAYWRIGHT_BASE_URL=https://fuzeatlas.com

# Test User Credentials
# These should match users in your test database
TEST_USER_EMAIL=test@fuzeatlas.com
TEST_USER_PASSWORD=TestPassword123!

# Test Invalid Credentials (for testing error states)
TEST_INVALID_EMAIL=invalid@fuzeatlas.com
TEST_INVALID_PASSWORD=WrongPassword123!

# Enable debug mode for verbose logging
DEBUG=pw:api

# Headless mode (set to false to see browser)
HEADED=false

# Slow motion - slow down actions (milliseconds)
SLOWMO=0

# Timeout for actions (milliseconds)
TIMEOUT=30000

# Screenshot on failure
SCREENSHOT_ON_FAILURE=true

# Video on failure
VIDEO_ON_FAILURE=true

# Trace on first retry
TRACE_ON_RETRY=true

# Reporter type (html, json, junit)
REPORTER=html

# CI Environment
# Set to true when running in CI/CD
CI=false
